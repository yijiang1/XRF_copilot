# === Frontend (NiceGUI) ===
HOST=0.0.0.0
PORT=8050
DEBUG=True

# Backend connection (where the FastAPI server runs)
API_ENDPOINT=http://localhost:8000

# API key for backend authentication (must match backend --api-key)
BACKEND_API_KEY=

# === Chat Assistant (Argo Gateway) ===
# Argonne username for Argo Gateway access
ANL_USERNAME=
ARGO_BASE_URL=https://apps.inside.anl.gov/argoapi/v1
ARGO_MODEL=gpt4o
