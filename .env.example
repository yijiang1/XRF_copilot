# === Frontend (NiceGUI) ===
HOST=0.0.0.0
PORT=8050
DEBUG=True

# Backend connection (where the FastAPI server runs)
API_ENDPOINT=http://localhost:8000

# API key for backend authentication (must match backend --api-key)
BACKEND_API_KEY=

# === APS Beam Status ===
# Set to "true" to show live APS beam status in the nav bar (ANL users only)
ENABLE_APS_STATUS=false

# === Chat Assistant (Argo Gateway) ===
# Requires Argonne network access. If the Argo endpoint is unreachable,
# the chat assistant will be disabled automatically.
# Argonne username for Argo Gateway access
ANL_USERNAME=
ARGO_BASE_URL=https://apps.inside.anl.gov/argoapi/v1
ARGO_MODEL=gpt4o
